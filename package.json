{
  "name": "synapse-desktop",
  "version": "1.0.0",
  "description": "Synapse Meeting Intelligence Desktop Agent",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "prisma:generate": "prisma generate && prisma generate --schema=backend/prisma/schema.prisma",
    "kill-electron": "powershell -Command \"Get-Process -Name electron -ErrorAction SilentlyContinue | Stop-Process -Force; Start-Sleep -Milliseconds 500\"",
    "electron:dev": "npm run build && npm run kill-electron && npm run prisma:generate && tsc -p tsconfig.electron.json && electron .",
    "electron:build": "npm run prisma:generate && npm run build && electron-builder"
  },
  "dependencies": {
    "@ai-sdk/openai": "^0.0.66",
    "@deepgram/sdk": "^3.3.0",
    "@mastra/core": "^0.10.15",
    "@prisma/client": "^5.22.0",
    "@qdrant/js-client-rest": "^1.11.0",
    "@supabase/supabase-js": "^2.39.0",
    "ai": "^3.4.7",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cross-fetch": "^4.1.0",
    "crypto-js": "^4.2.0",
    "d3": "^7.8.5",
    "dotenv": "^16.4.5",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.4",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "firebase-admin": "^13.0.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.0",
    "openai": "^4.67.3",
    "rate-limit-redis": "^4.2.0",
    "socket.io": "^4.8.0",
    "uuid": "^11.0.5",
    "winston": "^3.15.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.5",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.5.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.5.16",
    "prisma": "^5.22.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.10"
  }
}
