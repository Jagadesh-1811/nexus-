{
  "name": "@synapse/orchestrator",
  "version": "1.0.0",
  "description": "Synapse Meeting Intelligence Orchestrator — Mastra + TypeScript AI backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "auth:set-role": "tsx src/scripts/setRole.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^0.0.66",
    "@deepgram/sdk": "^3.3.0",
    "@mastra/core": "^0.10.15",
    "@prisma/client": "^5.20.0",
    "@qdrant/js-client-rest": "^1.11.0",
    "ai": "^3.4.7",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "firebase-admin": "^13.0.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.0",
    "openai": "^4.67.3",
    "pg": "^8.22.0",
    "rate-limit-redis": "^4.2.0",
    "socket.io": "^4.8.0",
    "uuid": "^11.0.5",
    "winston": "^3.15.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.23.8"
